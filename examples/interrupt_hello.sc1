# Example: interrupt_hello
# Goal: print "HELLO" and newline via software interrupts.
# Run:
#   python3 run_sc1.py examples/interrupt_hello.sc1
#   python3 run_sc1.py examples/interrupt_hello.sc1 --pygame
# Expected:
#   HELLO
#
# INT IDs used:
#   1: putc (prints chr(ACC & 0xFF))
#   3: newline

1 72 0
48 1
1 69 0
48 1
1 76 0
48 1
1 76 0
48 1
1 79 0
48 1
48 3
15
